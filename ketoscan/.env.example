# ===========================================
# Planeta Keto Scan - Variables de entorno
# ===========================================
# Copia este archivo a .env.local y rellena los valores reales.
# .env.local NUNCA debe subirse a git.

# --- Base de datos PostgreSQL ---
DATABASE_URL=postgresql://usuario:password@localhost:5432/ketoscan

# --- Anthropic API (solo server-side, nunca NEXT_PUBLIC) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Sesion: secreto para firmar (HMAC) la cookie de login multiusuario ---
SESSION_SECRET=pon-un-secreto-largo-y-aleatorio

# --- App ---
NEXT_PUBLIC_APP_NAME=Planeta Keto Scan
# Vacío: la app se sirve en la raíz del subdominio scan.planetaketo.es
NEXT_PUBLIC_BASE_PATH=
NODE_ENV=production
